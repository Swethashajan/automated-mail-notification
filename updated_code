    'DATASET_COUNT',
    'DS_BNDRY_ID',
    'DS_ID',
    'DS_NAME',
    'LO_CONTACT',               # semicolon or comma-separated email(s)
    'SCHEDULED_DLVRY_END_DATE',
    'DELIVERY_TYPE',
    'FILE_PATTERN',
]

# ── Email HTML template  (unchanged from original send_delay_emails.py) ──────
EMAIL_TEMPLATE = """
